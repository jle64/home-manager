layout {

    focus-ring {
        active-color   "#86ceff"
        inactive-color "#131313"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#86ceff"
        inactive-color "#131313"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#86ceff"
        inactive-color "#004c6d"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#86ceff80"
    }
}

recent-windows {
    highlight {
        active-color "#86ceff"
        urgent-color "#ffb4ab"
    }
}
