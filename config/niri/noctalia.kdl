layout {

    border {
        active-color   "#4d57a9"
        inactive-color "#f9f9f9"
        urgent-color   "#ba1a1a"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#4d57a9"
        inactive-color "#dfe0ff"
        urgent-color   "#ba1a1a"
    }

    insert-hint {
        color "#4d57a980"
    }
}

recent-windows {
    highlight {
        active-color "#4d57a9"
        urgent-color "#ba1a1a"
    }
}
